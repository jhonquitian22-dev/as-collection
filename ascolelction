var BC={Valentino:'#8B0000',Chanel:'#1a1a1a',YSL:'#111',Creed:'#2c3e50','Paco Rabanne':'#b8960c','Tom Ford':'#2d1810','Carolina Herrera':'#8B4789','Jean Paul Gaultier':'#4A5568',Dior:'#0a0a2e','Giorgio Armani':'#2F4F4F',Gucci:'#006341',Versace:'#c4a800','Maison Francis Kurkdjian':'#800020',Prada:'#222','Emporio Armani':'#1C3144','Louis Vuitton':'#5D4037','Parfums de Marly':'#4A148C',Burberry:'#D0B49F',Azzaro:'#1565C0','Dolce & Gabbana':'#D32F2F'};
function gc(b){return BC[b]||'#555';}

var fS='',fB='all',_filtered=[];

window.onload=function(){
  document.getElementById('logoImg').src='data:image/jpeg;base64,'+D.logo;
  var brands=[];
  var seen={};
  D.perfumes.forEach(function(p){if(!seen[p.brand]){seen[p.brand]=1;brands.push(p.brand);}});
  brands.sort();
  var sel=document.getElementById('bsel');
  brands.forEach(function(b){
    var o=document.createElement('option');
    o.value=b;
    var c=D.perfumes.filter(function(p){return p.brand===b;}).length;
    o.textContent=b+' ('+c+')';
    sel.appendChild(o);
  });
  document.getElementById('q').addEventListener('input',function(e){fS=e.target.value.toLowerCase();render();});
  sel.addEventListener('change',function(e){fB=e.target.value;render();});
  render();
};

function fil(){
  return D.perfumes.filter(function(p){
    var ms=fS===''||p.name.toLowerCase().indexOf(fS)>=0||p.brand.toLowerCase().indexOf(fS)>=0||p.code.toLowerCase().indexOf(fS)>=0;
    var mb=fB==='all'||p.brand===fB;
    return ms&&mb;
  });
}

function render(){
  var f=fil();
  _filtered=f;
  document.getElementById('cnt').textContent=f.length+' '+(f.length===1?'fragancia':'fragancias')+(fS||fB!=='all'?' encontradas':' disponibles');
  if(!f.length){
    document.getElementById('grid').innerHTML='';
    document.getElementById('emp').style.display='block';
    return;
  }
  document.getElementById('emp').style.display='none';
  var html='';
  for(var i=0;i<f.length;i++){
    var p=f[i];
    html+='<div class="cd" onclick="openM('+i+')">';
    html+='<div class="ci"><img src="data:image/jpeg;base64,'+p.img+'" alt="'+p.name+'" loading="lazy">';
    html+='<div class="cc">'+p.code+'</div>';
    html+='<div class="bd" style="background:'+gc(p.brand)+'"></div></div>';
    html+='<div class="cb"><div class="cbr" style="color:'+gc(p.brand)+'">'+p.brand+'</div>';
    html+='<h3 class="cn">'+p.name+'</h3>';
    html+='<div class="cf"><span class="cp">'+p.capacity+'</span><span class="cta">Detalles →</span></div>';
    html+='</div></div>';
  }
  document.getElementById('grid').innerHTML=html;
}

function openM(i){
  var p=_filtered[i];
  document.getElementById('mImg').src='data:image/jpeg;base64,'+p.img;
  document.getElementById('mBrand').textContent=p.brand;
  document.getElementById('mBrand').style.color=gc(p.brand);
  document.getElementById('mTitle').textContent=p.name;
  document.getElementById('mCap').textContent=p.capacity;
  document.getElementById('mCode').textContent=p.code;
  document.getElementById('mDesc').textContent=p.description;
  document.getElementById('modal').classList.add('on');
  document.getElementById('modal').onclick=function(e){if(e.target===this)closeM();};
}

function closeM(){document.getElementById('modal').classList.remove('on');}

function clearF(){
  fS='';fB='all';
  document.getElementById('q').value='';
  document.getElementById('bsel').value='all';
  render();
}

document.addEventListener('keydown',function(e){if(e.key==='Escape')closeM();});
</script>
