<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#030305;--bg2:#0a0a0f;--gold:#d4a853;--gold-light:#fef3c7;--gold-dim:rgba(212,168,83,0.6);--card-bg:rgba(18,18,22,0.9);--border:rgba(212,168,83,0.15);--bh:rgba(212,168,83,0.4)}
body{font-family:'Montserrat',sans-serif;background:var(--bg);color:#fff;-webkit-font-smoothing:antialiased}

.hero{background:linear-gradient(180deg,#0c0a08 0%,var(--bg) 100%);border-bottom:1px solid var(--border);padding:56px 20px 48px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-100px;left:50%;transform:translateX(-50%);width:700px;height:700px;background:radial-gradient(circle,rgba(212,168,83,0.07) 0%,transparent 70%);pointer-events:none}
.logo{width:110px;height:110px;object-fit:contain;margin:0 auto 18px;display:block;filter:drop-shadow(0 4px 24px rgba(212,168,83,0.25));border-radius:12px}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(40px,8vw,80px);font-weight:300;letter-spacing:.12em;color:var(--gold-light);line-height:1}
.sub{font-size:clamp(13px,2.5vw,19px);color:var(--gold-dim);font-weight:300;letter-spacing:.08em;margin-top:10px}
.prices-row{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:32px}
.pb{background:linear-gradient(135deg,rgba(212,168,83,0.08),rgba(120,53,15,0.12));border:1px solid var(--border);border-radius:14px;padding:20px 30px;min-width:210px;position:relative}
.pb.bk{border-color:rgba(168,85,247,0.25);background:linear-gradient(135deg,rgba(168,85,247,0.08),rgba(88,28,135,0.12))}
.pb .tg{position:absolute;top:-10px;right:14px;background:var(--gold);color:#000;font-size:9px;font-weight:700;padding:3px 10px;border-radius:20px;text-transform:uppercase;letter-spacing:.05em}
.pb .lb{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--gold-dim);margin-bottom:4px}
.pb .am{font-size:40px;font-weight:700;color:var(--gold-light)}
.pb .nt{font-size:11px;color:rgba(255,255,255,0.4);margin-top:2px}

.fl{position:sticky;top:0;z-index:40;background:rgba(5,5,8,0.93);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:12px 20px}
.fli{max-width:1240px;margin:0 auto;display:flex;gap:12px;flex-wrap:wrap;align-items:center}
.si{flex:1;min-width:200px;padding:10px 18px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;color:var(--gold-light);font-family:inherit;font-size:13px;transition:border .3s}
.si::placeholder{color:rgba(212,168,83,0.3)}
.si:focus{outline:none;border-color:var(--bh)}
.bs{min-width:180px;padding:10px 18px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;color:var(--gold-light);font-family:inherit;font-size:13px;cursor:pointer}
.bs:focus{outline:none;border-color:var(--bh)}
.bs option{background:#111;color:#eee}
.ct{width:100%;font-size:11px;color:var(--gold-dim);margin-top:4px}

.cat{max-width:1240px;margin:0 auto;padding:32px 20px 60px}
.gr{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}

.cd{background:var(--card-bg);border:1px solid var(--border);border-radius:14px;overflow:hidden;cursor:pointer;transition:transform .3s,border-color .3s,box-shadow .3s}
.cd:hover{transform:translateY(-4px);border-color:var(--bh);box-shadow:0 12px 40px rgba(0,0,0,0.5)}

.ci{position:relative;aspect-ratio:1/0.9;background:linear-gradient(135deg,#1a1a1e,#141416);overflow:hidden;display:flex;align-items:center;justify-content:center}
.ci img{width:85%;height:85%;object-fit:contain;transition:transform .4s ease}
.cd:hover .ci img{transform:scale(1.06)}
.cc{position:absolute;top:8px;left:8px;background:rgba(0,0,0,0.55);backdrop-filter:blur(6px);padding:3px 9px;border-radius:20px;font-size:10px;font-weight:600;color:var(--gold);border:1px solid rgba(212,168,83,0.2)}
.bd{position:absolute;top:8px;right:8px;width:8px;height:8px;border-radius:50%}

.cb{padding:14px 16px 16px}
.cbr{font-size:9px;text-transform:uppercase;letter-spacing:.14em;font-weight:600;margin-bottom:4px;opacity:.85}
.cn{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:600;color:var(--gold-light);line-height:1.25;transition:color .3s;margin-bottom:8px}
.cd:hover .cn{color:var(--gold)}
.cf{display:flex;justify-content:space-between;align-items:center}
.cp{font-size:11px;color:var(--gold-dim)}
.cta{font-size:9px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:.06em}

.mbg{display:none;position:fixed;inset:0;z-index:50;background:rgba(0,0,0,0.82);backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:16px}
.mbg.on{display:flex}
.md{background:linear-gradient(160deg,#16161a,#0e0e12);border-radius:20px;max-width:580px;width:100%;max-height:90vh;overflow-y:auto;border:1px solid var(--border);box-shadow:0 30px 60px rgba(0,0,0,0.7)}
.mdi{aspect-ratio:16/10;background:linear-gradient(135deg,#1e1e22,#141416);display:flex;align-items:center;justify-content:center;padding:24px;position:relative}
.mdi img{max-height:200px;object-fit:contain;filter:drop-shadow(0 8px 20px rgba(0,0,0,0.5))}
.mx{position:absolute;top:12px;right:12px;width:34px;height:34px;border-radius:50%;background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.1);color:var(--gold);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;transition:background .3s}
.mx:hover{background:rgba(0,0,0,0.8)}
.mi{padding:24px}
.mi .mbrand{font-size:11px;text-transform:uppercase;letter-spacing:.14em;font-weight:500;margin-bottom:6px}
.mi .mtitle{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:700;color:var(--gold-light);margin-bottom:6px}
.mi .mmeta{display:flex;gap:12px;align-items:center;color:var(--gold-dim);font-size:13px;margin-bottom:20px}
.mi .dot{color:rgba(212,168,83,0.3)}
.mi .mcode{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:rgba(212,168,83,0.5)}
.msep{border-top:1px solid var(--border);padding-top:18px;margin-top:18px}
.mst{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;color:var(--gold);margin-bottom:8px}
.mdesc{color:rgba(254,243,199,0.75);line-height:1.7;font-size:14px;font-style:italic}
.mpr{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:18px}
.mprb{border-radius:10px;padding:12px;border:1px solid var(--border)}
.mprb.a{background:rgba(120,53,15,0.12)}
.mprb.b{background:rgba(88,28,135,0.12);border-color:rgba(168,85,247,0.2)}
.mprb .pl{font-size:9px;text-transform:uppercase;letter-spacing:.06em;color:var(--gold-dim);margin-bottom:2px}
.mprb .pa{font-size:24px;font-weight:700;color:var(--gold-light)}

.wa{position:fixed;bottom:20px;right:20px;z-index:45;width:56px;height:56px;background:linear-gradient(135deg,#25d366,#128c3e);border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;color:#fff;box-shadow:0 4px 20px rgba(37,211,102,0.4);transition:transform .3s;animation:wp 2.5s ease-in-out infinite}
.wa:hover{transform:scale(1.12)}
.wa svg{width:26px;height:26px}
@keyframes wp{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,0.4)}50%{box-shadow:0 4px 35px rgba(37,211,102,0.7)}}

.ft{border-top:1px solid var(--border);padding:24px 20px;text-align:center;background:rgba(5,5,8,0.6)}
.ft p{font-size:12px;color:var(--gold-dim)}
.ft .fc{font-size:10px;color:rgba(212,168,83,0.3);margin-top:6px}

.emp{text-align:center;padding:60px 20px}
.emp p{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--gold-dim);margin-bottom:16px}
.emp button{padding:10px 20px;background:rgba(212,168,83,0.1);border:1px solid var(--border);border-radius:10px;color:var(--gold-light);font-family:inherit;cursor:pointer;transition:background .3s}
.emp button:hover{background:rgba(212,168,83,0.2)}

::-webkit-scrollbar{width:8px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:rgba(212,168,83,0.2);border-radius:4px}

@media(max-width:640px){
  .gr{grid-template-columns:repeat(2,1fr);gap:10px}
  .cb{padding:10px 12px 12px}
  .cn{font-size:14px}
  .cp{font-size:10px}
  .cbr{font-size:8px}
  .mi .mtitle{font-size:24px}
  .prices-row{flex-direction:column;align-items:center}
}
</style>
</head>
